charter "Agent Autonomy Grant" v1.0

schemas: canon.ai@2026.01

packages:
    - ai_governance
    - authorization
    - certification
    - evidence
    - policy

policies:
    - ai.agent_autonomy

triggers:
    model_submitted
    review_completed
    deployment_requested

workflow agent_autonomy_grant:
    phase eligibility:
        await model_submitted
        require require_bias_assessment_documented()
        require require_human_review_present()
        action check_grant_eligibility()
        evidence eligibility_record

    phase facts:
        require eligibility.passed
        require require_human_review_present()
        require verify_human_review_complete()
        action submit_facts()
        evidence facts_packet

    phase safety_evaluation:
        require facts.passed
        require require_bias_assessment_documented()
        action submit_safety_eval()
        action run_adversarial_tests()
        evidence safety_evaluation_report
        certify hashable

    phase guardrails:
        require safety_evaluation.passed
        require verify_approval_chain_complete()
        action configure_guardrails()
        action verify_guardrail_coverage()
        evidence guardrail_configuration
        certify hashable

    phase safeguards:
        require guardrails.passed
        await review_completed
        require verify_chain_of_custody_complete()
        action test_safeguards()
        action verify_escalation_path()
        evidence safeguards_verification

    phase monitoring:
        require safeguards.passed
        require verify_approval_chain_complete()
        action activate_monitoring()
        action verify_real_time_alerting()
        evidence monitoring_configuration

    phase approvals:
        require monitoring.passed
        await deployment_requested
        require verify_executive_approval()
        action collect_approvals()
        action verify_approval_signatures()
        evidence approval_packet
        certify immutable

    phase policy:
        require approvals.passed
        require evaluate_policy()
        action evaluate_policy()
        evidence policy_result

    phase certification:
        require policy.passed
        action emit_certificate()
        certify immutable
        evidence agent_autonomy_certificate

situations:
    when current_autonomy_level == "UNKNOWN":
        require require_human_review_present()

    when target_autonomy_level == "UNKNOWN":
        require require_human_review_present()

    when target_autonomy_level == "L4_AUTONOMOUS":
        require verify_board_approval()

    when domain_scope == "FINANCIAL":
        require require_human_review_for_high_risk()
        require verify_cfo_approval()

    when domain_scope == "HR":
        require require_human_review_for_high_risk()

    when domain_scope == "SECURITY":
        require require_human_review_for_high_risk()
        require verify_ciso_approval()

    when domain_scope == "UNKNOWN":
        require require_human_review_present()

    when execution_environment == "PROD":
        require require_bias_assessment_documented()

    when execution_environment == "UNKNOWN":
        require require_human_review_present()

    when blast_radius == "ORGANIZATION":
        require require_human_review_for_high_risk()

    when blast_radius == "EXTERNAL":
        require require_human_review_for_high_risk()

    when blast_radius == "CROSS_SYSTEM":
        require verify_executive_approval()

    when blast_radius == "UNKNOWN":
        require require_human_review_present()

    when human_escalation_path == "NOT_AVAILABLE":
        require require_human_review_for_high_risk()

    when human_escalation_path == "UNKNOWN":
        require require_human_review_present()

    when rollback_capability == "NONE":
        require require_human_review_for_high_risk()

    when rollback_capability == "UNKNOWN":
        require require_human_review_present()

    when capability_includes_admin == "YES":
        require verify_ciso_approval()

    when capability_includes_transactions == "YES":
        require verify_cfo_approval()

roles:
    head_of_ai:
        actions: [check_grant_eligibility, submit_facts, submit_safety_eval, configure_guardrails, collect_approvals, emit_certificate]
        requires_mfa: true

    ml_engineer:
        actions: [run_adversarial_tests, verify_guardrail_coverage, test_safeguards, verify_escalation_path]
        requires_mfa: true

    sre:
        actions: [activate_monitoring, verify_real_time_alerting]
        requires_mfa: true

    ciso:
        actions: [verify_approval_signatures, collect_approvals, emit_certificate]
        requires_mfa: true
        break_glass: true

    cfo:
        actions: [collect_approvals, emit_certificate]
        requires_mfa: true
        break_glass: true

    ceo:
        actions: [collect_approvals, verify_approval_signatures, emit_certificate]
        requires_mfa: true
        break_glass: true
